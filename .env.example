# ──────────────────────────────────────────────────────────
# Database
# For Docker installs, docker-compose.yml sets this automatically.
# Only set it here for local development.
# ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://soundstash:soundstash@localhost:5432/soundstash"

# ──────────────────────────────────────────────────────────
# Auth (required)
# ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-secret"

# Public URL of the app (used for cookie domain, redirects, and invite links)
BETTER_AUTH_URL="http://localhost:8089"
NEXT_PUBLIC_APP_URL="http://localhost:8089"

# ──────────────────────────────────────────────────────────
# Admin account (created on first boot if it doesn't exist)
# ──────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# ──────────────────────────────────────────────────────────
# Email / SMTP (required to send invite emails)
# The app starts without these, but invites cannot be sent.
# ──────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="SoundStash <noreply@example.com>"

# ──────────────────────────────────────────────────────────
# App (optional)
# ──────────────────────────────────────────────────────────
# Shown in email subjects. Defaults to "SoundStash".
APP_NAME="SoundStash"
