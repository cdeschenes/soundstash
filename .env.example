# Database
DATABASE_URL="postgresql://soundstash:password@localhost:5432/soundstash"

# Better Auth
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-secret"
BETTER_AUTH_URL="http://localhost:3232"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3232"
APP_NAME="SoundStash"

# Email (nodemailer SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="SoundStash <noreply@example.com>"

# Admin seed
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
